{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "depcheck: current dir (lib only)",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "presentation": { "group": "1_cli", "order": 1 }
    },
    {
      "name": "depcheck: self (bin,test)",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "args": ["-f", "bin,test", "-e", "lints,test,cider"],
      "presentation": { "group": "1_cli", "order": 2 }
    },
    {
      "name": "depcheck: --help",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "args": ["--help"],
      "presentation": { "group": "1_cli", "order": 3 }
    },
    {
      "name": "depcheck: --json",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "args": ["-f", "bin,test", "-e", "lints,test,cider", "--json"],
      "presentation": { "group": "1_cli", "order": 4 }
    },
    {
      "name": "Run example",
      "type": "dart",
      "request": "launch",
      "program": "example/lib/example.dart",
