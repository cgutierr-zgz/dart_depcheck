{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "depcheck: current dir (lib only)",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "presentation": { "group": "1_cli", "order": 1 }
    },
    {
      "name": "depcheck: self (bin,test)",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "args": ["-f", "bin,test", "-e", "lints,test,cider"],
      "presentation": { "group": "1_cli", "order": 2 }
    },
    {
      "name": "depcheck: --help",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "args": ["--help"],
      "presentation": { "group": "1_cli", "order": 3 }
    },
    {
      "name": "depcheck: --json",
      "type": "dart",
      "request": "launch",
      "program": "bin/dart_depcheck.dart",
      "args": ["-f", "bin,test", "-e", "lints,test,cider", "--json"],
      "presentation": { "group": "1_cli", "order": 4 }
    },
    {
      "name": "Run example",
      "type": "dart",
      "request": "launch",
      "program": "example/lib/example.dart",
      "presentation": { "group": "2_example", "order": 1 }
    },
    {
      "name": "Run tests",
      "type": "dart",
      "request": "launch",
      "program": "test/dart_depcheck_test.dart",
      "presentation": { "group": "3_test", "order": 1 }
    },
    {
      "name": "Release: patch (x.x.+1)",
      "type": "dart",
      "request": "launch",
      "program": "tool/release.dart",
      "args": ["patch", "--push"],
      "console": "integratedTerminal",
      "presentation": { "group": "4_release", "order": 1 }
    },
    {
      "name": "Release: minor (x.+1.0)",
      "type": "dart",
      "request": "launch",
      "program": "tool/release.dart",
      "args": ["minor", "--push"],
      "console": "integratedTerminal",
      "presentation": { "group": "4_release", "order": 2 }
    },
    {
      "name": "Release: major (+1.0.0)",
      "type": "dart",
      "request": "launch",
      "program": "tool/release.dart",
      "args": ["major", "--push"],
      "console": "integratedTerminal",
      "presentation": { "group": "4_release", "order": 3 }
    }
  ]
}
